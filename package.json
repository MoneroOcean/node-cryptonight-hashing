{
  "name": "node-pow-hashing",
  "version": "29.1.6",
  "description": "Native Node.js bindings for proof-of-work hashing families including CryptoNight, RandomX, KawPow, Ethash, Cuckaroo29, and more.",
  "main": "index.js",
  "exports": {
    ".": "./index.js"
  },
  "gypfile": true,
  "files": [
    "index.js",
    "check_cpu.sh",
    "binding.gyp",
    "README.md",
    "*.cc",
    "*.h",
    "c29/**",
    "xmrig/**",
    "xmrig-override/**"
  ],
  "sideEffects": false,
  "author": {
    "name": "Multiple",
    "email": "Check The Git Repo"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MoneroOcean/node-pow-hashing.git"
  },
  "homepage": "https://github.com/MoneroOcean/node-pow-hashing#readme",
  "engines": {
    "node": ">=18"
  },
  "os": [
    "linux",
    "darwin"
  ],
  "scripts": {
    "test": "node --test --test-concurrency=1 --test-reporter=spec tests/stability.js",
    "test:perf": "node --test --test-concurrency=1 --test-reporter=spec tests/perf.js",
    "test:all": "node --test --test-concurrency=1 --test-reporter=spec tests/stability.js tests/perf.js"
  },
  "dependencies": {
    "bindings": "1.5.0",
    "blake2": "5.0.1",
    "nan": "2.26.2"
  },
  "keywords": [
    "pow",
    "hashing",
    "cryptonight",
    "randomx",
    "cuckaroo29",
    "argon2",
    "astrobwt",
    "KangarooTwelve",
    "monero",
    "kawpow"
  ]
}
